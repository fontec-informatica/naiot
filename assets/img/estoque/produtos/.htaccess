# Impedir execução de PHP e listagem nesta pasta de uploads
Options -Indexes -ExecCGI
<FilesMatch "\.(php|php[0-9]|phtml|pht|phar)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>
